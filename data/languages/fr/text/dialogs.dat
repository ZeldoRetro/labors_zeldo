dialog{
  id = "LABORS.1st_solarus_quest.hyrule_field.great_shop.card_employee_card_npc",
  skip = "current",
  text = [[
Bienvenue au Grand Magasin
Monsieur. Si vous voulez parler
affaires, allez de l'autre côté.
Moi ? Et bien je travaille ici
depuis 10 ans et je n'avais pas
de dialogue jusqu'à ce que
j'imagine que des petits curieux
comme Kakash/Raz voudraient tenter
de me parler... merci les gars.
]],
}

