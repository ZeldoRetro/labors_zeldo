]],
}

dialog{
  id = "LABORS.1st_solarus_quest.hyrule_field.great_shop.welcome_grade_gold",
  skip = "all",
  text = [[
Soyez le bienvenue Monseigneur.
Bienvenue dans la Section Or.
Regardez donc mes articles rares.
Des produits spéciaux pour vous,
O Membre d'Or. Vous ne trouverez
pas de meilleure qualité ! Slurrp.
]],
}

dialog{
  id = "LABORS.1st_solarus_quest.hyrule_field.great_shop.welcome_grade_normal",
