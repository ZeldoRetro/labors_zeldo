dialog{
  id = "_treasure.inventory/echange.1",
  icon = "30",
  text = [[
Tu obtiens un Bocal
d'Epices ! $0

Sa couleur orange manquera
à son propriétaire mais c'est
un ingrédient essentiel à
la Cuvée Romani... amenez-le
vite au gérant du bar !
]],
}

dialog{
  id = "_treasure.inventory/echange.2",
  icon = "31",
  text = [[
Tu obtiens un Flocon 
de Sucre ! $0

Cela peut paraitre comme de
la glace ordinaire mais elle
possède un arome sucré.
C'est un ingrédient qui donne
tout son goût à la Cuvée 
Romani. Amenez-le au bar !
]],
}

dialog{
  id = "_treasure.inventory/echange.3",
  icon = "32",
  text = [[
Tu obtiens du Miel ! $0


Quelques gouttes suffiront
à donner à la Cuvée Romani
son goût irrésistible.
Cela devrait être le dernier
ingrédient pour la préparer !
]],
}

dialog{
  id = "_treasure.inventory/echange_1st_solarus_quest.1",
  icon = "30",
  text = [[
Tu obtiens un Miroir ! $0
Tu peux te voir dedans...
qu'est-ce que tu es beau !
Quelqu'un dans ce Village
pourrait en avoir besoin ?
Mène ton enquête !
Utilise-le avec Objet 1
ou Objet 2 sur la bonne
personne pour l'échanger.
]],
}

dialog{
  id = "_treasure.inventory/echange_1st_solarus_quest.2",
  icon = "31",
  text = [[
Tu obtiens un Balai
neuf ! $0
Bien joué ?
Idéal pour redonner la
pêche à une maniaque
du ménage !
Utilise-le avec Objet 1
ou Objet 2 sur la bonne
personne pour l'échanger.
]],
}

dialog{
  id = "_treasure.inventory/echange_1st_solarus_quest.3",
  icon = "32",
  text = [[
Tu obtiens une Pierre
précieuse ! $0
Il s'agit d'un diamant...
Brillant d'une innocence
étincelante, connaitrais-tu
une personne intéressée ?
Utilise-la avec Objet 1
ou Objet 2 sur la bonne
personne pour l'échanger.
]],
}

dialog{
  id = "_treasure.inventory/echange_1st_solarus_quest.4",
  icon = "33",
  text = [[
Tu obtiens un Ouvrage
