dialog{
  id = "inn.npc",
  skip = "current",
  text = [[
Bienvenue à l'Auberge. Si vous
désirez réserver une Chambre,
allez de l'autre côté du comptoir.
Moi ? Et bien je travaille ici
depuis 5 ans et je n'avais pas
de dialogue jusqu'à ce que
Kakash essaie de m'adresser
la parole. Comme quoi, lire et
parler aux pnjs c'est important !
]],
}

dialog{
  id = "inn.question",
  question = "1",
  skip = "current",
  text = [[
Bienvenue à l'Auberge. Voulez-vous 
vous reposer ? Une Chambre vous 
coûtera $v Rubis.
Séjourner ici ?
Oui
Non
]],
}

dialog{
  id = "inn.question_castle_town",
  question = "1",
  skip = "current",
  text = [[
Bienvenue au Manoir de la 
Citadelle, l'Auberge 3 étoiles
du Royaume !
Voulez-vous vous reposer ? Nous
avons un rabais pour un temps
limité !
Une Chambre ne vous coûtera
que $v Rubis. C'est une offre
à ne pas rater !
Séjourner ici ?
Oui
Non
]],
}

