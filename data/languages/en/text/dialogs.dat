]],
}

dialog{
  id = "shop.welcome_labors",
  skip = "all",
  text = [[
Welcome traveler !
I am the Keeper of the
Upgrade Cards.
These precious Cards will
grant you a permanent Upgrade
during the Zones of the Wave !
These Upgrades are various and
you can disable them if you want
in the Quest Status Menu.
All of them are for you
my friend... if  you have
enough Rupees...
]],
}

dialog{
  id = "shop.welcome_labors_permanent",
  skip = "all",
  text = [[
Welcome, traveler !
I am the Keeper of
Permanent Wave Items.
These precious Items will appear
as you progress
through the Labor Zones.
These Items have the special feature
of being granted to you permanently
within the current Wave.
They will allow you to discover secrets
in Zones you've already visited.
Pure extra fun !
In exchange for precious,
real and permanent Rupees,
these Items will be yours.
]],
}

dialog{
  id = "shop.welcome_labors_potion",
  skip = "all",
  text = [[
Welcome stranger.
It's always good to have a potion
on hand before setting off.
Don't buy it without
an empty bottle though !
]],
}

dialog{
  id = "shop.welcome_labors_remembrance",
  skip = "all",
  text = [[
Welcome traveler.
I am the Keeper of the
Gallery Keys.
Each one will grant you access
to exclusive development content.

(I'm not really sure what that
means but Lord Zeldo gave me
this dialogue...)
In exchange for Remembrance
Shards, I can materialize and hand
over these valuable Keys to you.
]],
}

dialog{
  id = "shop.welcome_merchant",
