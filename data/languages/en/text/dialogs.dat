dialog{
  id = "vire.1.appear",
  text = [[
So you're finally here...
]],
}

dialog{
  id = "vire.1.end",
  text = [[
Not bad for a mere kid...
It seems I've
underestimated you.
I'll let you live,
for now.
Hehehe...
You'll soon understand
that Death was a better fate
than what awaits you.
We will meet again !
Take what remains of
Din's Pearl... I offer it to you !
Hehehe...
]],
}

dialog{
  id = "vire.1.intro",
  text = [[
Hehehe... as Master Ganondorf predicted. 

I suppose you've come
for Din's Pearl ?

I regret to inform you that it
is no longer here ! Not entirely
at least... hehehe...
My name is Vire and I have come
here on my Master's orders for 2 things...
The first : To ensure that a
young blond boy could not find
Din's Pearl.
The second : To get rid of
this young boy !

So I have only one
thing left to do...
En garde !
]],
}

dialog{
  id = "vire.1.phase_1",
  skip = "current",
  text = [[
You're doing quite well...
But will you be able to keep
up the pace ?
]],
}

dialog{
  id = "vire.1.phase_2",
  skip = "current",
  text = [[
Well done ! But from now on,
don't count on
your Sword to reach me.
]],
}

